{
  "name": "@elephant/site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node ./scripts/patch-docusaurus-bundler.mjs",
    "sync:content": "node ./scripts/sync-install-script.mjs && node ./scripts/sync-skillhub-content.mjs",
    "start": "npm run sync:content && docusaurus start --host 127.0.0.1",
    "build": "npm run sync:content && docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "typecheck": "npm run sync:content && tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@docusaurus/theme-mermaid": "3.10.0",
    "@mdx-js/react": "^3.1.0",
    "@mermaid-js/layout-elk": "0.1.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/react": "^19.0.0",
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": ">=20.0"
  }
}
